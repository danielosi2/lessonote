{
  "version": 2,
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/generate", "destination": "/api/generate.js" },
    { "source": "/api/curriculum", "destination": "/api/curriculum.js" },
    { "source": "/api/week", "destination": "/api/week.js" },
    { "source": "/api/cache/stats", "destination": "/api/cache/stats.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
